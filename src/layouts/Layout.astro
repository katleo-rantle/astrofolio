---
import '../stlyes/global.css';

const { title = "Your Name - Portfolio" } = Astro.props;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content="Portfolio of Your Name - Developer & Writer" />
  
  <!-- Basic SEO -->
  <link rel="icon" href="/favicon.ico" />
  
  <!-- You can add Tailwind or other styles here -->
</head>
<body class="bg-white dark:bg-gray-950 text-gray-900 dark:text-gray-100 min-h-screen">
  <!-- Navigation -->
  <nav class="border-b border-gray-200 dark:border-gray-800 bg-white/80 dark:bg-gray-950/80 backdrop-blur-md sticky top-0 z-50">
    <div class="max-w-6xl mx-auto px-6 py-5 flex items-center justify-between">
      <a href="/" class="text-2xl font-bold tracking-tight">YourName</a>
      
      <div class="flex items-center gap-8 text-sm font-medium">
        <a href="/" class="hover:text-blue-600 transition">Home</a>
        <a href="/projects" class="hover:text-blue-600 transition">Projects</a>
        <a href="/blog" class="hover:text-blue-600 transition">Blog</a>
        <a href="/about" class="hover:text-blue-600 transition">About</a>
      </div>
    </div>
  </nav>

  <!-- Main Content -->
  <slot />

  <!-- Footer -->
  <footer class="border-t border-gray-200 dark:border-gray-800 mt-20 py-12">
    <div class="max-w-6xl mx-auto px-6 text-center text-sm text-gray-500 dark:text-gray-400">
      <p>© {new Date().getFullYear()} Your Name. Built with <a href="https://astro.build" target="_blank" class="hover:text-blue-600">Astro</a>.</p>
    </div>
  </footer>
</body>
</html>