---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allBlogPosts = await getCollection('blog');
const allProjects = await getCollection('projects');

const featuredProjects = allProjects.filter(p => p.data.featured);
const recentPosts = allBlogPosts
  .filter(post => !post.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);
---

<Layout title="Your Name - Portfolio">
  <main class="max-w-6xl mx-auto px-6 py-12">

    <!-- Hero Section -->
    <section class="text-center py-16">
      <h1 class="text-5xl font-bold mb-4">Hi, I'm Your Name</h1>
      <p class="text-xl text-gray-600 dark:text-gray-400">
        Full Stack Developer &amp; Content Creator
      </p>
    </section>

    <!-- Featured Projects -->
    <section class="mb-20">
      <h2 class="text-3xl font-semibold mb-8">Featured Projects</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {featuredProjects.map(project => (
          <div class="border rounded-xl overflow-hidden hover:shadow-xl transition">
            {project.data.image && (
              <img 
                src={project.data.image} 
                alt={project.data.title}
                class="w-full h-48 object-cover"
              />
            )}
            <div class="p-6">
              <h3 class="font-semibold text-xl mb-2">{project.data.title}</h3>
              <p class="text-gray-600 dark:text-gray-400 mb-4">
                {project.data.description}
              </p>
              <div class="flex flex-wrap gap-2 mb-4">
                {project.data.technologies.map(tech => (
                  <span class="text-xs bg-gray-100 dark:bg-gray-800 px-3 py-1 rounded-full">
                    {tech}
                  </span>
                ))}
              </div>
              <div class="flex gap-4">
                {project.data.github && <a href={project.data.github} class="text-blue-600 hover:underline">GitHub</a>}
                {project.data.liveUrl && <a href={project.data.liveUrl} class="text-blue-600 hover:underline">Live Demo</a>}
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Recent Blog Posts -->
    <section>
      <div class="flex justify-between items-center mb-8">
        <h2 class="text-3xl font-semibold">Recent Writing</h2>
        <a href="/blog" class="text-blue-600 hover:underline">View all posts →</a>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        {recentPosts.map(post => (
          <a href={`/blog/${post.id}`} class="group">
            <article class="border rounded-xl overflow-hidden hover:shadow-xl transition h-full flex flex-col">
              {post.data.image && (
                <img 
                  src={post.data.image} 
                  alt={post.data.title}
                  class="w-full h-48 object-cover"
                />
              )}
              <div class="p-6 flex-1 flex flex-col">
                <time class="text-sm text-gray-500">
                  {new Date(post.data.date).toLocaleDateString('en-US', { 
                    year: 'numeric', month: 'long', day: 'numeric' 
                  })}
                </time>
                <h3 class="font-semibold text-xl mt-3 mb-3 group-hover:text-blue-600 transition">
                  {post.data.title}
                </h3>
                <p class="text-gray-600 dark:text-gray-400 line-clamp-3">
                  {post.data.description}
                </p>
              </div>
            </article>
          </a>
        ))}
      </div>
    </section>

  </main>
</Layout>